      <div class="car-slide"><img src="/images/WhatsApp Image 2026-03-20 at 23.45.36.jpeg" alt="Resultado Método Goleiro 2.0" /></div>
      <div class="car-slide"><img src="/images/WhatsApp Image 2026-03-20 at 23.45.36 (1).jpeg" alt="Resultado Método Goleiro 2.0" /></div>
      <div class="car-slide"><img src="/images/WhatsApp Image 2026-03-20 at 23.45.36 (2).jpeg" alt="Resultado Método Goleiro 2.0" /></div>
      <div class="car-slide"><img src="/images/WhatsApp Image 2026-03-20 at 23.45.37.jpeg" alt="Resultado Método Goleiro 2.0" /></div>
      <div class="car-slide"><img src="/images/WhatsApp Image 2026-03-20 at 23.45.37 (1).jpeg" alt="Resultado Método Goleiro 2.0" /></div>
      <div class="car-slide"><img src="/images/WhatsApp Image 2026-03-20 at 23.45.37 (2).jpeg" alt="Resultado Método Goleiro 2.0" /></div>
      <div class="car-slide"><img src="/images/WhatsApp Image 2026-03-20 at 23.45.37 (3).jpeg" alt="Resultado Método Goleiro 2.0" /></div>
      <div class="car-slide"><img src="/images/WhatsApp Image 2026-03-20 at 23.45.37 (4).jpeg" alt="Resultado Método Goleiro 2.0" /></div>
    </div>
    <button class="car-btn car-prev" id="car-prev" aria-label="Anterior">&#8592;</button>
