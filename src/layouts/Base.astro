---
interface Props {
  title?: string;
}
const { title = "Método Goleiro 2.0 | Preparação Física para Goleiros" } = Astro.props;
---
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <!-- Google Tag Manager -->
  <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
  new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
  j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
  'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
  })(window,document,'script','dataLayer','GTM-PB46F2V8');</script>
  <!-- End Google Tag Manager -->

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow+Condensed:wght@400;600;700;800&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet" />
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:       #0A0A0A;
      --card:     #111111;
      --neon:     #DFFF00;
      --neon-dim: rgba(223,255,0,.07);
      --white:    #F5F5F5;
      --gray:     #888;
      --muted:    #666666;
      --border:   #222;
      --selected: #141a00;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--white);
      font-family: 'Barlow Condensed', sans-serif;
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* grain */
    body::after {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
      opacity: .03;
      pointer-events: none;
      z-index: 9999;
    }

    .page {
      position: relative;
      z-index: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 0 16px 100px;
    }

    .hr {
      width: 100%;
      max-width: 680px;
      height: 1px;
      background: linear-gradient(to right, transparent, var(--muted), transparent);
      margin: 8px 0;
    }

    .section-tag {
      font-family: 'JetBrains Mono', monospace;
      font-size: .65rem;
      font-weight: 700;
      color: var(--neon);
      letter-spacing: .2em;
      text-transform: uppercase;
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 16px;
    }
    .section-tag::before { content: '//'; color: var(--muted); }

    .reveal {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity .6s ease, transform .6s ease;
    }
    .reveal.in { opacity: 1; transform: translateY(0); }

    :focus-visible {
      outline: 2px solid var(--neon);
      outline-offset: 3px;
    }

    @keyframes shake {
      0%,100% { transform: translateX(0); }
      20%      { transform: translateX(-8px); }
      40%      { transform: translateX(8px); }
      60%      { transform: translateX(-5px); }
      80%      { transform: translateX(5px); }
    }
    @keyframes blink {
      0%,100% { opacity: 1; }
      50%      { opacity: .2; }
    }
    @keyframes pulse {
      0%   { box-shadow: 0 0 0 0 rgba(223,255,0,.5), 0 8px 40px rgba(223,255,0,.2); }
      55%  { box-shadow: 0 0 0 16px rgba(223,255,0,0), 0 8px 40px rgba(223,255,0,.2); }
      100% { box-shadow: 0 0 0 0 rgba(223,255,0,0), 0 8px 40px rgba(223,255,0,.2); }
    }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(8px); }
      to   { opacity: 1; transform: translateY(0); }
    }
  </style>
</head>
<body>
  <!-- Google Tag Manager (noscript) -->
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-PB46F2V8"
  height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
  <!-- End Google Tag Manager (noscript) -->

  <slot />
</body>
</html>
